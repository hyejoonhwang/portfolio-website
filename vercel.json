{
  "headers": [
    {
      "source": "/(.*)\\.mp4",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=31536000, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/thumbnails/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=31536000, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
